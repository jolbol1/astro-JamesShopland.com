---
import ChannelCardsFallback from "./channel-cards-fallback.astro"
import ChannelCardsIsland from "./channel-cards-island.astro"
---

<div class="mx-auto mt-12 max-w-6xl px-4 sm:px-8">
  <h2
    id="channels-heading"
    class="mb-4 font-medium uppercase tracking-widest text-blue-11"
  >
    Channels
  </h2>
  <ChannelCardsIsland
    server:defer
    aria-labelledby="channels-heading"
  >
    <ChannelCardsFallback
      slot="fallback"
      aria-labelledby="channels-heading"
    />
  </ChannelCardsIsland>

</div>
